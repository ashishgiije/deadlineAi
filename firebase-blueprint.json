{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile stored upon successful registration",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier of the user matching Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's primary email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display or full name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time the user account was initialized"
        }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project Document",
      "description": "A software project being monitored and managed by the AI",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns the project"
        },
        "name": {
          "type": "string",
          "description": "Name of the project"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the project"
        },
        "status": {
          "type": "string",
          "enum": ["planning", "active", "risk", "completed", "overdue"],
          "description": "Current status of the project"
        },
        "progress": {
          "type": "integer",
          "description": "Percentage completion (0 to 100)"
        },
        "deadline": {
          "type": "string",
          "format": "date",
          "description": "Deadline date of the project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time when the project was created"
        }
      },
      "required": ["userId", "name", "status", "progress", "deadline", "createdAt"]
    },
    "Notification": {
      "title": "Notification Log",
      "description": "System-generated notification log for risk detection and actions",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the user who should receive the notification"
        },
        "projectId": {
          "type": "string",
          "description": "Associated project ID"
        },
        "projectName": {
          "type": "string",
          "description": "Associated project name"
        },
        "type": {
          "type": "string",
          "enum": ["warning", "info", "success", "danger"],
          "description": "Severity type of the notification"
        },
        "title": {
          "type": "string",
          "description": "Short title of the notification message"
        },
        "message": {
          "type": "string",
          "description": "Full notification content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "read": {
          "type": "boolean",
          "description": "True if user has read/dismissed the notification"
        }
      },
      "required": ["userId", "projectId", "type", "title", "message", "createdAt", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user profile storage"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of software delivery projects"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notification logs"
    }
  }
}
